# Claude / local tools
.claude
.claude/*
temp_*

# macOS
.DS_Store

# Plastic SCM
.plastic

# Editor
.vscode

# ---- Unity (cFS_DockingSim/) ----

# Generated by Unity at import/build time - never commit these
cFS_DockingSim/[Ll]ibrary/
cFS_DockingSim/[Tt]emp/
cFS_DockingSim/[Oo]bj/
cFS_DockingSim/[Ll]ogs/

# Build output
cFS_DockingSim/[Bb]uild/
cFS_DockingSim/[Bb]uilds/

# Per-user editor preferences (layout, recent files, etc.)
cFS_DockingSim/[Uu]ser[Ss]ettings/

# IDE project files - Unity regenerates these on open
cFS_DockingSim/*.csproj
cFS_DockingSim/*.sln
cFS_DockingSim/*.slnx
cFS_DockingSim/.vs/

# Telemetry log output
cFS_DockingSim/TelemetryLog_*.csv

# Blender source files — too large for GitHub without LFS; keep locally only
*.blend
*.blend1

# 3D model and texture files — keep locally and sync via OneDrive instead
*.fbx
cFS_DockingSim/Assets/Models/**/*.jpg
cFS_DockingSim/Assets/Models/**/*.jpeg
cFS_DockingSim/Assets/Models/**/*.png
